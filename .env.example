# =============================================================================
# Makovetzky ERP — environment variables.
# Copy this file to `.env` for local dev. Set the same keys on Vercel for prod.
# Variables marked REQUIRED will cause the app to crash or refuse to start
# without them. OPTIONAL variables degrade gracefully when missing.
# =============================================================================

# -----------------------------------------------------------------------------
# Database — REQUIRED
# -----------------------------------------------------------------------------
# Supabase Postgres pooled connection. The app uses this for every runtime
# read/write. Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# In Supabase: Project → Settings → Database → "Connection pooling" string.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/makovetzky_erp?schema=public"

# Direct (non-pooled) connection used by `prisma migrate` only. In Supabase:
# Project → Settings → Database → "Connection string (URI)". Leave empty when
# the DB isn't behind a pooler (local dev with raw Postgres is fine without it).
DIRECT_URL=""

# -----------------------------------------------------------------------------
# Auth.js v5 (NextAuth) — REQUIRED
# -----------------------------------------------------------------------------
# Cryptographic secret used to sign session JWTs. Generate with:
#   openssl rand -base64 33
# Never reuse across environments — rotate by changing here and re-deploying.
AUTH_SECRET=""

# -----------------------------------------------------------------------------
# Public app URL — REQUIRED (graceful degrade if missing)
# -----------------------------------------------------------------------------
# Absolute origin (no trailing slash) used to build customer-facing links:
# proposal signing links, WhatsApp reminder URLs, magic links for field
# uploads, etc. Without this, links in outbound WhatsApp messages will be
# relative paths and won't work outside the browser.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Supabase Storage — REQUIRED
# -----------------------------------------------------------------------------
# Used by every document upload, the signed PDF flow for proposals, and the
# outbound WhatsApp media path. Service-role key is server-side only — never
# expose to the client.
# In Supabase: Project → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=""             # e.g. https://abcd1234.supabase.co
SUPABASE_SERVICE_ROLE_KEY=""            # service_role secret. KEEP PRIVATE.

# -----------------------------------------------------------------------------
# Vercel cron — REQUIRED for proposal reminders
# -----------------------------------------------------------------------------
# vercel.json schedules /api/cron/proposal-reminders daily at 09:00 UTC. The
# cron handler verifies this secret via the Authorization header (Vercel
# injects "Bearer <CRON_SECRET>" automatically when the var is set) or a
# ?secret= query param. Generate via `openssl rand -hex 32`.
CRON_SECRET=""

# -----------------------------------------------------------------------------
# WhatsApp — Green API (preferred, QR-based) — OPTIONAL
# -----------------------------------------------------------------------------
# Drives every outbound WhatsApp message the system sends:
#   - Forgot-password tokens to users
#   - Proposal signing reminders to customers (cron)
#   - "Customer signed!" notifications to admins
#   - Send-to-group from /projects/[id]/whatsapp
#   - Outbound media via sendFileByUrl (Batch 5)
# Without these the related features silently no-op. Sign up at
# console.green-api.com → create instance → scan QR.
GREEN_API_ID_INSTANCE=""                # numeric instance id
GREEN_API_TOKEN_INSTANCE=""             # API token for that instance

# Identity of the system's WhatsApp number, used by the inbound webhook to
# detect @system mentions in group messages. Without these, mention parsing
# in group chats won't match anything and only reply-to-system fallbacks
# will route messages to the inbox.
SYSTEM_WHATSAPP_PHONE=""                # E.164 digits, e.g. 972501234567
SYSTEM_WHATSAPP_NAME=""                 # display string used by mention parser, e.g. "Makovetzky System"

# -----------------------------------------------------------------------------
# WhatsApp — Meta Cloud API (alternative) — OPTIONAL
# -----------------------------------------------------------------------------
# Independent inbound webhook at /api/whatsapp/webhook for businesses using
# Meta's official Cloud API instead of Green API. Skip this section if Green
# API is enough. Get values from developers.facebook.com → your App →
# WhatsApp → API Setup.
WHATSAPP_VERIFY_TOKEN=""                # random string also pasted into Meta webhook config
WHATSAPP_ACCESS_TOKEN=""                # permanent System User token (whatsapp_business_messaging)
WHATSAPP_PHONE_NUMBER_ID=""             # numeric ID of your sending number (NOT the phone itself)
WHATSAPP_APP_SECRET=""                  # App Settings → Basic → App Secret; used to verify X-Hub-Signature-256
WHATSAPP_DISPLAY_PHONE_NUMBER=""        # optional display string for /settings/whatsapp, e.g. "+972 50 123 4567"

# -----------------------------------------------------------------------------
# Generic webhook secret — REQUIRED if Green API or any other bridge is used
# -----------------------------------------------------------------------------
# Shared secret that gates /api/webhooks/green-api and /api/webhooks/whatsapp.
# Caller must send it as the X-Webhook-Secret header OR ?secret= query param.
# Generate via `openssl rand -hex 32` and paste the same value into:
#   - Green API console → Settings → outgoingMessageWebhook URL's ?secret=
#   - Any other webhook bridges you wire up.
WHATSAPP_WEBHOOK_SECRET=""

# -----------------------------------------------------------------------------
# PDF rendering on Vercel — OPTIONAL
# -----------------------------------------------------------------------------
# The proposal signing flow renders signed PDFs via @sparticuz/chromium-min,
# which downloads chromium from a remote pack file at lambda cold-start. The
# default URL points to v149.0.0 — override here only if you've mirrored a
# specific chromium build (e.g. on an internal CDN for compliance reasons).
CHROMIUM_PACK_URL=""

# Local Windows / macOS dev: if `puppeteer` (the auto-downloading package)
# isn't installed, point this at an existing Chrome/Chromium binary so the
# PDF renderer can still work. Ignored on Vercel.
# Example: PUPPETEER_EXECUTABLE_PATH="C:\Program Files\Google\Chrome\Application\chrome.exe"
PUPPETEER_EXECUTABLE_PATH=""
