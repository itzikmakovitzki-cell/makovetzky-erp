# PostgreSQL connection string. Replace with your actual database URL.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/makovetzky_erp?schema=public"

# Direct connection (for migrations on poolers like Supabase / pgbouncer).
# Leave empty if not behind a pooler.
DIRECT_URL=""

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# WhatsApp Cloud API (Meta). Required for /api/whatsapp/webhook.
# Get these from developers.facebook.com → your App → WhatsApp → API Setup.
WHATSAPP_VERIFY_TOKEN=""               # Random string you also paste into Meta Webhook config
WHATSAPP_ACCESS_TOKEN=""               # Permanent System User token (whatsapp_business_messaging)
WHATSAPP_PHONE_NUMBER_ID=""            # Numeric ID of your sending number (NOT the phone itself)
WHATSAPP_APP_SECRET=""                 # App Settings → Basic → App Secret; used to verify X-Hub-Signature-256
WHATSAPP_DISPLAY_PHONE_NUMBER=""       # Optional display string for the settings page, e.g. "+1 555 123 4567"

# Generic provider-agnostic webhook for /api/webhooks/whatsapp
# (Twilio / Green API / MessageBird / custom bridges).
# Caller must send this value as X-Webhook-Secret header OR ?secret= query param.
WHATSAPP_WEBHOOK_SECRET=""             # Random string; rotate by regenerating + updating both sides
