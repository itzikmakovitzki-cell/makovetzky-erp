// Makovetzky Project Management — Bureaucracy & Permitting ERP
//
// Hierarchy: Client → MasterDeal → Permit → Building
// Currency: ILS only (no multi-currency).
// Tasks/Checklists/Milestones live at the Permit level.
// Documents may be tagged to Permit, Building, and/or Task.
// AuditLog is immutable by convention — enforce at application layer.

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev, "rhel-openssl-3.0.x" for Vercel/AWS Lambda.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================================
// ENUMS
// =============================================================

enum UserRole {
  ADMIN
  EMPLOYEE
  CONTRACTOR
}

enum MasterDealStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum PermitStatus {
  DRAFT
  IN_PROGRESS
  AWAITING_AUTHORITY
  COMPLETED
  CANCELLED
}

// AWAITING_AUTHORITY on a Task pairs with Task.frozen = true to
// freeze due dates and suppress overdue notifications.
enum TaskStatus {
  OPEN
  IN_PROGRESS
  AWAITING_AUTHORITY
  COMPLETED
  BLOCKED
}

enum TaskPriority {
  NORMAL
  URGENT
}

enum TaskResponsibility {
  INTERNAL
  CLIENT
  CONTRACTOR
  AUTHORITY
}

enum MilestoneStatus {
  PENDING
  DUE
  PAID
}

enum SupplierAssignmentStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// How a supplier's commission is structured. FIXED = flat ILS amount per
// event/assignment; PERCENT = percentage of the deal amount (computed at
// commission-resolution time, see app/actions/suppliers.ts).
enum SupplierCommissionType {
  FIXED
  PERCENT
}

enum CommissionReportStatus {
  DRAFT
  SENT
  PAID
}

enum PendingDocumentStatus {
  PENDING
  ASSIGNED
  REJECTED
}

enum DocumentSourceChannel {
  WHATSAPP
  EMAIL
  PORTAL
  MANUAL
}

// Lifecycle of a standalone proposal. DRAFT → SENT → SIGNED (or REJECTED).
// Once SIGNED, the admin can convert into Client + MasterDeal + DealMilestones.
enum ProposalStatus {
  DRAFT
  SENT
  SIGNED
  REJECTED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  ASSIGN
  DEPENDENCY_OVERRIDE
  APPROVE
  REJECT
}

// Lifecycle of an AuthoritySubmission (Block 26). Tracks the PM's flow of
// "I gathered all docs in this category → I sent the bundle to the authority
// → I'm waiting → the authority responded". Per (permit, category) pair.
enum AuthoritySubmissionStatus {
  PREPARING
  SUBMITTED
  APPROVED
  REJECTED
}

// =============================================================
// USERS & PORTAL ACCESS
// =============================================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(EMPLOYEE)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedTasks            Task[]
  defaultAssignedTemplates TaskTemplate[]
  uploadedDocuments        Document[]           @relation("DocumentUploader")
  approvedDocuments        Document[]           @relation("DocumentApprover")
  notes                    Note[]
  overriddenDependencies   TaskDependency[]
  weeklySummariesEdited    WeeklySummaryDraft[]
  auditLogs                AuditLog[]
  portalAccesses           PortalAccess[]
  createdProposals         Proposal[]           @relation("ProposalCreator")
  // Submissions this user marked as sent to the authority.
  authoritySubmissions     AuthoritySubmission[]

  @@index([role])
}

// Multiple users can have portal access to a single client (contractor + staff).
model PortalAccess {
  id        String   @id @default(cuid())
  clientId  String
  userId    String
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clientId, userId])
  @@index([userId])
}

// Single-use field-worker access. Token is the lookup key; expiresAt drives validity.
model MagicLink {
  id        String    @id @default(cuid())
  token     String    @unique
  taskId    String?
  permitId  String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  // Block 20: 48h-TTL magic links die with the permit/task they were minted
  // for — there's no reason to keep an unusable dangling link around.
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  permit Permit? @relation(fields: [permitId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([taskId])
  @@index([permitId])
}

// =============================================================
// CORE HIERARCHY: Client → MasterDeal → Permit → Building
// =============================================================

// B2B clients only: companyName/contactName/phone are required identification fields.
// hp = ח.פ. (Israeli company registration number). email/address/notes optional.
// Soft delete: deletedAt != null means hidden everywhere except /settings/recycle-bin.
model Client {
  id          String    @id @default(cuid())
  companyName String
  hp          String?
  contactName String
  phone       String
  email       String?
  address     String?
  notes       String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  masterDeals    MasterDeal[]
  portalAccesses PortalAccess[]
  proposals      Proposal[]

  @@index([companyName])
  @@index([deletedAt])
}

model MasterDeal {
  id           String           @id @default(cuid())
  clientId     String
  name         String
  contractDate DateTime?
  totalValue   Decimal?         @db.Decimal(14, 2)
  status       MasterDealStatus @default(ACTIVE)
  notes        String?
  deletedAt    DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  client         Client          @relation(fields: [clientId], references: [id], onDelete: Restrict)
  permits        Permit[]
  dealMilestones DealMilestone[]
  proposals      Proposal[]

  @@index([clientId])
  @@index([status])
  @@index([deletedAt])
}

model Permit {
  id                String       @id @default(cuid())
  masterDealId      String
  authorityId       String
  permitNumber      String?
  name              String
  type              String?
  status            PermitStatus @default(DRAFT)
  progressPercent   Int          @default(0)
  startDate         DateTime?
  expectedCloseDate DateTime?
  closedAt          DateTime?
  deletedAt         DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // Block 20: deleting a deal cascades to its permits (and from there to
  // their tasks, billing milestones, documents, notes). The previous Restrict
  // blocked the cleanup path the admin actually wanted.
  masterDeal       MasterDeal           @relation(fields: [masterDealId], references: [id], onDelete: Cascade)
  authority        Authority            @relation(fields: [authorityId], references: [id], onDelete: Restrict)
  buildings        Building[]
  tasks            Task[]
  documents        Document[]
  notes            Note[]
  milestones       BillingMilestone[]
  magicLinks       MagicLink[]
  weeklySummaries  WeeklySummaryDraft[]
  pendingDocuments PendingDocument[]
  authoritySubmissions AuthoritySubmission[]

  @@index([masterDealId])
  @@index([authorityId])
  @@index([status])
  @@index([expectedCloseDate])
  @@index([deletedAt])
}

// Block 26: one row per (permit, category) — tracks the authority-side
// lifecycle. Category is the same free-text value as Task.category; we
// intentionally keep them as plain strings (rather than introducing a
// Category table) to match how the PM thinks about them.
model AuthoritySubmission {
  id            String                    @id @default(cuid())
  permitId      String
  category      String
  status        AuthoritySubmissionStatus @default(PREPARING)
  // Set when status transitions to SUBMITTED.
  submittedAt   DateTime?
  // Set when status transitions to APPROVED or REJECTED.
  decidedAt     DateTime?
  // Free-text capture of the authority's note (e.g. "missing form X").
  decisionNotes String?
  submittedById String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  permit      Permit @relation(fields: [permitId], references: [id], onDelete: Cascade)
  submittedBy User?  @relation(fields: [submittedById], references: [id], onDelete: SetNull)

  @@unique([permitId, category])
  @@index([permitId])
  @@index([status])
}

model Building {
  id        String   @id @default(cuid())
  permitId  String
  label     String
  type      String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  permit    Permit     @relation(fields: [permitId], references: [id], onDelete: Cascade)
  documents Document[]

  @@index([permitId])
}

// =============================================================
// TASKS, TEMPLATES, AUTHORITIES, DEPENDENCIES (strict AND)
// =============================================================

model Authority {
  id          String   @id @default(cuid())
  name        String   @unique
  region      String?
  contactInfo String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  wikiEntries   AuthorityWikiEntry[]
  taskTemplates TaskTemplate[]
  permits       Permit[]
}

model AuthorityWikiEntry {
  id          String   @id @default(cuid())
  authorityId String
  title       String
  contentMd   String
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authority Authority @relation(fields: [authorityId], references: [id], onDelete: Cascade)

  @@index([authorityId])
}

model BuildingType {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  taskTemplates TaskTemplate[]
}

model TaskTemplate {
  id                  String              @id @default(cuid())
  authorityId         String
  buildingTypeId      String
  name                String
  description         String?
  defaultDurationDays Int?
  // Days from the project base date when the task is expected to *start*.
  // Used by the Gantt/Timeline view to plot the bar's left edge; the existing
  // task-generation logic (which computes dueDate from defaultDurationDays)
  // is unchanged.
  defaultStartOffsetDays Int?
  orderIndex          Int                 @default(0)
  isActive            Boolean             @default(true)
  // Free-text classification (e.g. "שלד", "אישורי רשויות"). Imported from Excel as-is.
  category            String?
  // Which party owns the task by default. Inherited by generated Task rows.
  responsibility      TaskResponsibility?
  // Free-form labels. Stored as Postgres text[]; filter via { has: x }.
  tags                String[]            @default([])
  // Optional default assignee applied to every task generated from this
  // template (createProject / addPermitToDeal). Null = unassigned.
  defaultAssigneeId   String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  authority       Authority    @relation(fields: [authorityId], references: [id], onDelete: Restrict)
  buildingType    BuildingType @relation(fields: [buildingTypeId], references: [id], onDelete: Restrict)
  defaultAssignee User?        @relation(fields: [defaultAssigneeId], references: [id], onDelete: SetNull)
  tasks           Task[]

  dependsOn    TaskTemplateDependency[] @relation("TemplateDependent")
  dependedOnBy TaskTemplateDependency[] @relation("TemplateDependedOn")

  @@unique([authorityId, buildingTypeId, name])
  @@index([authorityId, buildingTypeId])
  @@index([category])
  @@index([responsibility])
  @@index([tags], type: Gin)
  @@index([defaultAssigneeId])
}

model TaskTemplateDependency {
  templateId          String
  dependsOnTemplateId String

  template          TaskTemplate @relation("TemplateDependent", fields: [templateId], references: [id], onDelete: Cascade)
  dependsOnTemplate TaskTemplate @relation("TemplateDependedOn", fields: [dependsOnTemplateId], references: [id], onDelete: Cascade)

  @@id([templateId, dependsOnTemplateId])
  @@index([dependsOnTemplateId])
}

model Task {
  id          String              @id @default(cuid())
  permitId    String
  templateId  String?
  assigneeId  String?
  name        String
  description String?
  status      TaskStatus          @default(OPEN)
  priority    TaskPriority        @default(NORMAL)
  // Managerial Spotlight — pushes the task to the top of the assignee's queue.
  isSpotlight Boolean             @default(false)
  // True while status = AWAITING_AUTHORITY. Freezes due date and suppresses overdue alerts.
  frozen      Boolean             @default(false)
  // Block 25: how many times the due date was pushed via the Snooze action.
  // Surfaces chronic delays — a high count flags a task that keeps slipping.
  snoozeCount Int                 @default(0)
  // Free-text classification (e.g. "שלד", "אישורי רשויות"). Imported from Excel as-is.
  category    String?
  // Which party owns the task. Surfaced in portal so contractors see what's theirs.
  responsibility TaskResponsibility?
  // Free-form labels. Stored as Postgres text[]; filter via { has: x }.
  tags        String[]            @default([])
  // Planned start (different from startedAt which records when work actually began).
  // Used by the Gantt/Timeline view; nullable to keep all legacy tasks valid.
  startDate   DateTime?
  dueDate     DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  permit              Permit                   @relation(fields: [permitId], references: [id], onDelete: Cascade)
  template            TaskTemplate?            @relation(fields: [templateId], references: [id], onDelete: SetNull)
  assignee            User?                    @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  dependsOn           TaskDependency[]         @relation("TaskDependent")
  dependedOnBy        TaskDependency[]         @relation("TaskDependedOn")
  documents           Document[]
  supplierAssignments SupplierTaskAssignment[]
  // 1:1 — a task may anchor at most one billing milestone.
  milestone           BillingMilestone?
  magicLinks          MagicLink[]
  pendingDocs         PendingDocument[]

  @@index([permitId, status])
  @@index([assigneeId, status])
  @@index([dueDate])
  @@index([assigneeId, isSpotlight])
  @@index([deletedAt])
  @@index([category])
  @@index([responsibility])
  @@index([tags], type: Gin)
}

// Strict AND semantics: a task becomes unblocked only when every dependsOn row is satisfied.
model TaskDependency {
  taskId            String
  dependsOnTaskId   String
  overriddenByAdmin Boolean   @default(false)
  overriddenAt      DateTime?
  overriddenById    String?

  task         Task  @relation("TaskDependent", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn    Task  @relation("TaskDependedOn", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)
  overriddenBy User? @relation(fields: [overriddenById], references: [id], onDelete: SetNull)

  @@id([taskId, dependsOnTaskId])
  @@index([dependsOnTaskId])
}

// =============================================================
// FINANCE: Billing Milestones, Suppliers, Commission Reports
// =============================================================

// 1:1 with Task — completion of triggerTask flips status to DUE and sends the alert.
model BillingMilestone {
  id            String          @id @default(cuid())
  permitId      String
  // Either triggerTaskId or triggerPercentage drives the milestone — exactly
  // one is set. The legacy 1:1 task trigger remains the default; percentage-
  // based triggers fire when the permit's overall task completion crosses the
  // threshold (e.g. 80% of tasks completed → DUE). Both nullable so existing
  // rows are valid and we can express either model without schema migration.
  triggerTaskId      String?    @unique
  triggerPercentage  Int?
  name          String
  amount        Decimal         @db.Decimal(14, 2)
  status        MilestoneStatus @default(PENDING)
  dueDate       DateTime?
  triggeredAt   DateTime?
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Block 20: billing milestones cascade out when their parent permit goes;
  // and when the anchor task is removed (also cascading from the permit) the
  // milestone goes with it instead of blocking the delete with a FK error.
  permit      Permit @relation(fields: [permitId], references: [id], onDelete: Cascade)
  triggerTask Task?  @relation(fields: [triggerTaskId], references: [id], onDelete: Cascade)

  @@index([permitId, status])
  @@index([status, dueDate])
}

model Supplier {
  id                     String   @id @default(cuid())
  name                   String
  // Short tag — "מודד" / "חשמלאי" / "מעבדה". Free text, with a frontend
  // datalist that auto-suggests previously-used values.
  type                   String?
  contactName            String?
  phone                  String?
  email                  String?
  website                String?
  // Long-form description of what the supplier provides ("בדיקות חשמל +
  // ייעוץ ת.ת אוטומציה"). Kept separate from `notes` so internal admin
  // notes stay private to the back office.
  services               String?
  // Phase 1 of the suppliers overhaul: commission split into (type, value)
  // so we can model either a fixed ILS amount or a percentage of the deal.
  // Per-assignment overrides land on SupplierTaskAssignment in phase 2.
  defaultCommissionType  SupplierCommissionType?
  defaultCommissionValue Decimal?                @db.Decimal(10, 2)
  // Free-text payment terms ("שוטף+30", "מקדמה 50%", "במזומן בסיום").
  defaultPaymentTerms    String?
  notes                  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  taskAssignments   SupplierTaskAssignment[]
  commissionReports SupplierCommissionReport[]

  @@index([name])
}

// Powers the cross-project "Bulk View" of open work per supplier.
model SupplierTaskAssignment {
  id          String                   @id @default(cuid())
  supplierId  String
  taskId      String
  // Legacy field — was the only "money" capture before phase 2. Kept for
  // backwards compatibility / freeform "deal size" notes; commission is
  // now computed from (commissionType, commissionValue) below, falling
  // back to the supplier's defaults when null on the assignment.
  amount      Decimal?                 @db.Decimal(14, 2)
  status      SupplierAssignmentStatus @default(OPEN)
  // Phase-2 fields. Null on either commission field = "inherit from
  // Supplier.defaultCommissionType / defaultCommissionValue". paymentTerms
  // null = "inherit Supplier.defaultPaymentTerms".
  commissionType  SupplierCommissionType?
  commissionValue Decimal?                @db.Decimal(10, 2)
  paymentTerms    String?
  // When the supplier paid us the commission. Drives the phase-4
  // "מה מגיע לי" dashboard at /finances/supplier-commissions.
  commissionPaidAt DateTime?
  dueDate     DateTime?
  completedAt DateTime?
  notes       String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([supplierId, status])
  @@index([taskId])
  @@index([commissionPaidAt])
}

model SupplierCommissionReport {
  id          String                 @id @default(cuid())
  supplierId  String
  periodYear  Int
  periodMonth Int
  totalDue    Decimal                @db.Decimal(14, 2)
  status      CommissionReportStatus @default(DRAFT)
  generatedAt DateTime               @default(now())
  sentAt      DateTime?
  paidAt      DateTime?
  notes       String?

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)

  @@unique([supplierId, periodYear, periodMonth])
  @@index([periodYear, periodMonth])
}

// =============================================================
// CONTENT: Documents (versioned), Notes (pinnable), Audit Log
// =============================================================

// Old versions are archived (never deleted). Exactly one row per logical
// document should have isLatestApproved = true; enforce at application layer.
// Soft delete via deletedAt — recoverable from /settings/recycle-bin.
model Document {
  id               String    @id @default(cuid())
  permitId         String
  buildingId       String?
  taskId           String?
  fileName         String
  fileUrl          String
  mimeType         String?
  sizeBytes        Int?
  version          Int       @default(1)
  isLatestApproved Boolean   @default(false)
  uploadedById     String?
  approvedById     String?
  approvedAt       DateTime?
  notes            String?
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Block 20: docs cascade out with their permit. Hard-deletes from the
  // recycle bin still hit storage cleanup via the application transaction.
  permit     Permit    @relation(fields: [permitId], references: [id], onDelete: Cascade)
  building   Building? @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  task       Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  uploadedBy User?     @relation("DocumentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  approvedBy User?     @relation("DocumentApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([permitId, isLatestApproved])
  @@index([buildingId])
  @@index([taskId])
  @@index([deletedAt])
}

model Note {
  id        String   @id @default(cuid())
  permitId  String
  content   String
  isPinned  Boolean  @default(false)
  authorId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  permit Permit @relation(fields: [permitId], references: [id], onDelete: Cascade)
  author User?  @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([permitId, isPinned, createdAt])
}

// Immutable: do not expose UPDATE or DELETE operations at the application layer.
// entityType is a free String to avoid migrations when new tracked models are added.
model AuditLog {
  id         String      @id @default(cuid())
  entityType String
  entityId   String
  action     AuditAction
  oldValue   Json?
  newValue   Json?
  userId     String?
  timestamp  DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([timestamp])
  @@index([userId])
}

// =============================================================
// EXTERNAL INTAKE: WhatsApp Document Catcher, Weekly Summaries
// =============================================================

model PendingDocument {
  id               String                @id @default(cuid())
  sourceChannel    DocumentSourceChannel @default(WHATSAPP)
  senderInfo       String?
  fileUrl          String
  fileName         String?
  mimeType         String?
  rawMessage       String?
  status           PendingDocumentStatus @default(PENDING)
  assignedTaskId   String?
  assignedPermitId String?
  rejectionReason  String?
  processedAt      DateTime?
  createdAt        DateTime              @default(now())

  assignedTask   Task?   @relation(fields: [assignedTaskId], references: [id], onDelete: SetNull)
  assignedPermit Permit? @relation(fields: [assignedPermitId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
}

model WeeklySummaryDraft {
  id           String    @id @default(cuid())
  permitId     String
  draftContent String
  generatedAt  DateTime  @default(now())
  sentAt       DateTime?
  editedById   String?
  updatedAt    DateTime  @updatedAt

  permit   Permit @relation(fields: [permitId], references: [id], onDelete: Cascade)
  editedBy User?  @relation(fields: [editedById], references: [id], onDelete: SetNull)

  @@index([permitId, generatedAt])
}

// =============================================================
// BLOCK 15: STANDALONE PROPOSALS
// =============================================================

// Lightweight quote/offer that does NOT force a Client/MasterDeal until
// signed. The cuid id doubles as the unguessable token for the public
// /quote/[id] signing page. After signature, the admin converts it into a
// real Client + MasterDeal + DealMilestone records via a one-shot action.
model Proposal {
  id              String         @id @default(cuid())
  // Lead-stage customer info — copied into the real Client at conversion.
  customerName    String
  customerPhone   String
  customerEmail   String?
  projectLocation String?
  totalAmount     Decimal        @db.Decimal(14, 2)
  // Payment schedule as a flexible JSON array. Each entry is
  // { description: string, amount: number, dueDate?: string (ISO) }.
  // Stays in JSON until conversion, then materialized as DealMilestone rows.
  milestones      Json
  terms           String?
  status          ProposalStatus @default(DRAFT)
  // Either a base64 PNG dataURL from the canvas signature pad, or a typed
  // full-name string. Storage is opaque; the UI knows how to render both.
  signatureData   String?
  signedName      String?
  signedAt        DateTime?
  // Free-text reason captured when the customer rejects the proposal.
  rejectionReason String?
  // Conversion linkage — null until the admin converts. Both are set
  // atomically by convertProposalToProject.
  clientId        String?
  masterDealId    String?
  convertedAt     DateTime?
  createdById     String?
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  client      Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  masterDeal  MasterDeal? @relation(fields: [masterDealId], references: [id], onDelete: SetNull)
  createdBy   User?       @relation("ProposalCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([clientId])
  @@index([masterDealId])
  @@index([createdAt])
  @@index([deletedAt])
}

// Deal-level payment milestones materialized from a converted Proposal.
// Distinct from BillingMilestone, which is permit-scoped and trigger-task
// based — these run on the deal layer and use plain due-dates.
model DealMilestone {
  id           String          @id @default(cuid())
  masterDealId String
  description  String
  amount       Decimal         @db.Decimal(14, 2)
  dueDate      DateTime?
  status       MilestoneStatus @default(PENDING)
  paidAt       DateTime?
  orderIndex   Int             @default(0)
  // Percentage of permit-tasks-completed at which this milestone is "ready
  // for billing". Used by the finances tab to surface a live progress bar
  // against the target — null = manual / date-driven only.
  triggerPercentage Int?
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  masterDeal MasterDeal @relation(fields: [masterDealId], references: [id], onDelete: Cascade)

  @@index([masterDealId, status])
  @@index([masterDealId, orderIndex])
}
